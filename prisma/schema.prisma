// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Club {
  id         String  @id @default(cuid())
  name       String
  email      String?
  provider   String?
  providerId String?
  verified   Boolean @default(false)
  events     Event[]
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  location    String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clubId String
  club   Club   @relation(fields: [clubId], references: [id])
  RSVP   RSVP[]
  achievements Achievement[]
}

// NEW: The User profile to track Gamification points
model User {
  id     String @id @default(cuid())
  name   String
  points Int    @default(0) // Everyone starts at 0
  rsvps  RSVP[]
  achievements Achievement[]
}

// NEW: The bridge table connecting Users and Events
model RSVP {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
  attended  Boolean  @default(false)

  // This ensures a user can only RSVP to a specific event ONE time
  @@unique([userId, eventId])
}

// NEW: The University Academic Calendar for Blackout Dates
model AcademicCalendar {
  id        String   @id @default(cuid())
  title     String   // e.g., "Mid-Semester Exams", "Diwali Break"
  startDate DateTime
  endDate   DateTime
  type      String   // e.g., "EXAM", "HOLIDAY", "FEST"
}

// NEW: Track achievements and verified accolades for users
model Achievement {
  id          String   @id @default(cuid())
  title       String   // e.g., "1st Place Winner", "Lead Organizer"
  description String?  // Optional context
  userId      String
  eventId     String
  user        User     @relation(fields: [userId], references: [id])
  event       Event    @relation(fields: [eventId], references: [id])
  verifiedAt  DateTime @default(now())
}